{
  "name": "klubu",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@oruga-ui/oruga-next": "^0.13.6",
    "@oruga-ui/theme-bulma": "^0.9.0",
    "axios": "^1.18.0",
    "date-fns": "^4.4.0",
    "js-base64": "^3.7.8",
    "material-symbols": "^0.45.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node18": "^18.2.6",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
